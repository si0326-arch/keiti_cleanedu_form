# 앱 환경변수 템플릿 — 이 파일을 복사해서 `.env` 로 만든 뒤 값을 채우세요.
#   로컬:   cp .env.example .env
#   Vercel: 대시보드 > Settings > Environment Variables 에 동일한 키로 등록
#
# ⚠️ Vite 규칙: VITE_ 접두어가 붙은 변수만 클라이언트(브라우저 번들)에 노출됩니다.
#    즉 VITE_ 변수는 "비밀이 아님" — 누구나 볼 수 있습니다.
#    진짜 비밀(예: Supabase service_role key)은 절대 VITE_ 로 두지 말고,
#    서버리스 함수의 서버 전용 환경변수로만 사용하세요.

# Supabase 연결 (publishable/anon 키 — 클라이언트 노출 OK, 보호는 RLS가 담당)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# ── 관리자 대시보드 (/admin) 전용 — 서버리스 함수 /api/submissions 에서만 사용 ──
# ⚠️ 아래 3개는 VITE_ 접두어 없음 = 브라우저에 노출되지 않는 서버 전용 비밀.
#    submissions 는 RLS로 anon 읽기 불가 → 이 함수가 service_role 로 읽고 비밀번호로 잠근다.
#    Vercel > Settings > Environment Variables 에 등록 (로컬 테스트는 `vercel dev` + 이 .env).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # 절대 공개·커밋 금지
ADMIN_PASSWORD=set-a-strong-admin-password
